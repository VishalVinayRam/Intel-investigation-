# Example Environment Configuration
# Copy this file to .env and update with your values
# DO NOT commit .env to version control!

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Threat Feed API Keys (Optional)
# Most feeds used in this POC are public and don't require keys
THREAT_FEED_API_KEY=

# Worker Configuration
FETCH_INTERVAL=300  # Fetch interval in seconds (5 minutes)
METRICS_PORT=8000   # Port for Prometheus metrics endpoint
LOG_LEVEL=INFO      # Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Application Settings
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Production Configuration (Examples)
# THREAT_FEED_API_KEY=your-actual-api-key-here
# REDIS_PASSWORD=secure-password-from-vault
# SENTRY_DSN=https://your-sentry-dsn
# DATADOG_API_KEY=your-datadog-key
